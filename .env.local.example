# DeepSeek Chat 模型（Day 3 起用）
DEEPSEEK_API_KEY=sk-your-deepseek-key

# 智谱 AI Embedding 模型（Day 2 起用）
ZHIPU_API_KEY=xxxxxxxx.xxxxxxxx

# Supabase 数据库
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=sb_secret_xxx

# Tavily Web 搜索（Day 4 起用）
TAVILY_API_KEY=tvly-your-tavily-key

# Cohere Rerank 交叉编码器精排（可选，无 key 时自动降级为纯 RRF）
COHERE_API_KEY=your-cohere-api-key

# MCP 协议（可选，启用后 Agent 通过 MCP Client 动态发现工具）
# Vercel 部署不支持 spawn 子进程，请不要在此环境开启
ENABLE_MCP=false
